# Waldrof — copy to .env for local development (never commit .env)

# Server
PORT=3000
HOST=0.0.0.0

# Perplexity / AI research (server-side only)
AI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Supabase — required for community, cache, RAG, auth
SUPABASE_URI=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional aliases (e.g. if migrating from Next.js tooling)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Embeddings (optional, for vector RAG)
OPENAI_API_KEY=

# Google Drive community catalog sync (optional — recursive folder scan into community_materials)
GOOGLE_DRIVE_CATALOG_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
# DRIVE_CATALOG_SYNC_ON_BOOT=1
# CRON_SECRET=  (protects GET/POST /api/cron/drive-catalog-sync)

# Make.com — checkout-link webhook (button click → return Grow payment URL only)
# MAKE_UPGRADE_WEBHOOK_URL=https://hook.eu1.make.com/atopa4q5ewidxqlwwe0e3lkyr2mzcf2g
# That scenario must return a checkout URL and must NOT call /api/webhooks/payment-success.

# Payment success callback from Grow → Make → POST /api/webhooks/payment-success
# Required body example:
#   { "email":"teacher@example.com", "plan":"annual_pro", "paymentStatus":"success" }
# Also accepted: paid:true, transactionId / asmachta, event:"payment_success"
# PAYMENT_WEBHOOK_SECRET=  (optional; when set, require Authorization: Bearer <secret>)
# MAKE_PAYMENT_WEBHOOK_SECRET=  (alias for PAYMENT_WEBHOOK_SECRET)
