# Waldrof — copy to .env for local development (never commit .env)

# Server
PORT=3000
HOST=0.0.0.0

# Perplexity / AI research (server-side only)
AI_API_KEY=
PERPLEXITY_API_KEY=

# Supabase — required for community, cache, RAG, auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional aliases (e.g. if migrating from Next.js tooling)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Embeddings (optional, for vector RAG)
OPENAI_API_KEY=
