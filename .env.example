# Waldrof — copy to .env for local development (never commit .env)

# Server
PORT=3000
HOST=0.0.0.0

# Perplexity / AI research (server-side only)
AI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Supabase — required for community, cache, RAG, auth
SUPABASE_URI=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional aliases (e.g. if migrating from Next.js tooling)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Embeddings (optional, for vector RAG)
OPENAI_API_KEY=

# Google Drive community catalog (shared teacher folders)
# Used for: recursive sync into community_materials, live catalog search,
# shortcut resolution, and Gemini 1.5 Pro community summaries (community_drive_archive).
#
# Setup guide: docs/google-drive-setup.md
# Pack a multi-line SA JSON file:
#   node scripts/format-env-json.js path/to/service-account.json
#   node scripts/format-env-json.js path/to/service-account.json --write-env
#
# PASTE THESE TWO VALUES:
# 1) GOOGLE_DRIVE_CATALOG_ROOT_FOLDER_ID
#    Canonical root: 1N50V9Njt3E6IQDX0OfktLM7qkhzyJ0Cs
#    https://drive.google.com/drive/folders/1N50V9Njt3E6IQDX0OfktLM7qkhzyJ0Cs
# 2) GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON
#    One-line JSON from format-env-json.js (no wrapping quotes around the {...})
#    Share the catalog folder with that service-account email (Viewer).
#    Expected client_email: waldorf-service@careful-trainer-483207-r9.iam.gserviceaccount.com
#    Optional fallback: place service-account.json in the project root.
GOOGLE_DRIVE_CATALOG_ROOT_FOLDER_ID=1N50V9Njt3E6IQDX0OfktLM7qkhzyJ0Cs
# Alias accepted by getCatalogRootFolderId (same folder id):
DRIVE_ROOT_FOLDER_ID=1N50V9Njt3E6IQDX0OfktLM7qkhzyJ0Cs
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=""
# User OAuth for uploads into personal My Drive (SA has no storage quota):
# Live site (recommended on Render):
#   1) Google Cloud → OAuth client type Web application
#      Redirect: https://waldrof.onrender.com/api/auth/google-drive/callback
#   2) Set CLIENT_ID + CLIENT_SECRET (+ CRON_SECRET) on Render
#   3) Run supabase/drive_oauth_credentials.sql in Supabase SQL editor
#   4) Open: https://waldrof.onrender.com/api/auth/google-drive?secret=YOUR_CRON_SECRET
# Local CLI alternative:
#   1) Create Desktop/Web OAuth client (redirect http://127.0.0.1:53682/oauth2callback)
#   2) node scripts/google-drive-oauth-setup.js --write-env
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
# GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
# Optional override (defaults to APP_BASE_URL + /api/auth/google-drive/callback):
# GOOGLE_DRIVE_OAUTH_REDIRECT_URI=https://waldrof.onrender.com/api/auth/google-drive/callback
# Optional Workspace domain-wide delegation (instead of user OAuth):
# GOOGLE_DRIVE_DELEGATE_EMAIL=owner@your-domain.com
# DRIVE_CATALOG_SYNC_ON_BOOT=1
# Upload DB → Drive (grade/topic folders + Gemini summaries):
#   npm run upload-community-drive            # dry-run
#   npm run upload-community-drive:apply      # write + summarize
# Organize + convert (needs OAuth or Shared Drive for uploads):
#   npm run organize-drive                    # dry-run
#   npm run organize-drive:apply              # write
# CRON_SECRET=  (protects Drive OAuth + GET/POST /api/cron/drive-catalog-sync)
#
# Also run in Supabase SQL editor:
#   supabase/community_drive_archive.sql
#   supabase/drive_oauth_credentials.sql
# (Gemini community summaries — separate from Perplexity cached_results)
#
# API:
#   POST /api/community-search      { "query":"רומא", "gradeId":"5" } — Drive citations only (no Gemini)
#   POST /api/community-summarizer  { "topic":"רומא", "gradeId":"5" } — on-demand Gemini summary + public archive
# Live search routes (pure-general-search / pure-phase-c) do NOT run community Drive summarization.

# Make.com — checkout-link webhook (button click → return Grow payment URL only)
# MAKE_UPGRADE_WEBHOOK_URL=https://hook.eu1.make.com/atopa4q5ewidxqlwwe0e3lkyr2mzcf2g
# That scenario must return a checkout URL and must NOT call /api/webhooks/payment-success.

# Payment success callback from Grow → Make → POST /api/webhooks/payment-success
# Required body example:
#   { "email":"teacher@example.com", "plan":"annual_pro", "paymentStatus":"success" }
# Also accepted: paid:true, transactionId / asmachta, event:"payment_success"
# PAYMENT_WEBHOOK_SECRET=  (optional; when set, require Authorization: Bearer <secret>)
# MAKE_PAYMENT_WEBHOOK_SECRET=  (alias for PAYMENT_WEBHOOK_SECRET)
