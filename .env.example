# Waldrof — copy to .env for local development (never commit .env)

# Server
PORT=3000
HOST=0.0.0.0

# Perplexity / AI research (server-side only)
AI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Supabase — required for community, cache, RAG, auth
SUPABASE_URI=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional aliases (e.g. if migrating from Next.js tooling)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Embeddings (optional, for vector RAG)
OPENAI_API_KEY=

# Google Drive community catalog sync (optional — recursive folder scan into community_materials)
GOOGLE_DRIVE_CATALOG_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
# DRIVE_CATALOG_SYNC_ON_BOOT=1
# CRON_SECRET=  (protects GET/POST /api/cron/drive-catalog-sync)

# Make.com — Pro upgrade checkout (Grow payment link generation)
# MAKE_UPGRADE_WEBHOOK_URL=https://hook.eu1.make.com/your-upgrade-scenario-id
