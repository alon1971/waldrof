{
  "name": "waldrof",
  "version": "1.0.0",
  "private": true,
  "description": "Waldorf pedagogy research PWA with Perplexity-backed API",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "upload-knowledge": "node scripts/upload-text.js",
    "sync-render": "node scripts/sync-render-env.js",
    "upgrade-archive": "node scripts/upgradeArchive.js",
    "rollback-archive": "node scripts/rollbackArchiveToTimestamp.js",
    "organize-drive": "node scripts/organize-and-convert.js --from-community --default-grade=7 --default-topic=כללי",
    "organize-drive:apply": "node scripts/organize-and-convert.js --apply --from-community --default-grade=7 --default-topic=כללי --min-pdf-bytes=0",
    "drive-oauth-setup": "node scripts/google-drive-oauth-setup.js --write-env",
    "upload-community-drive": "node scripts/upload-community-to-drive.js",
    "upload-community-drive:apply": "node scripts/upload-community-to-drive.js --apply --summarize",
    "summarize-community-drive": "node scripts/upload-community-to-drive.js --summarize-only"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "mammoth": "^1.9.0",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^1.1.1",
    "stripe": "^17.7.0"
  }
}
